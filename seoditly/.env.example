# seoditly environment — copy to .env.local and fill in.
# All values are SERVER-ONLY. Never prefix secrets with NEXT_PUBLIC_.

# --- Phase 3: Contact form (Resend) ---
# API key for transactional email via Resend (https://resend.com).
RESEND_API_KEY=
# Address contact-form submissions are sent to.
CONTACT_TO_EMAIL=
# Verified "from" address Resend sends as.
CONTACT_FROM_EMAIL=

# --- Phase 4: Auth & backend proxy ---
# Base URL of the NestJS SEO Audit backend, used server-side only by the proxy
# (app/api/proxy) and the API client. The browser never sees this — it only
# ever calls the same-origin /api/proxy/* route. Defaults to localhost:3000.
BACKEND_URL=http://localhost:3000
# Optional: secret for signing/verifying cookies. Phase 4 relies on httpOnly +
# Secure + SameSite=Lax cookies alone (no app-level cookie signing), so this is
# currently UNUSED. Leave blank unless a later phase opts into signed cookies.
COOKIE_SECRET=

# --- i18n: SEO canonical / hreflang ---
# Public site origin used as metadataBase so per-locale canonical + hreflang
# alternates resolve to absolute URLs. Non-secret (a public origin) but kept
# server-side (NOT NEXT_PUBLIC_). Defaults to http://localhost:3001 in dev.
SITE_URL=https://seoditly.com
