# PostgreSQL connection string. Must match docker-compose.yml credentials.
# Required; validated as reachable on boot (a SELECT 1 ping runs during bootstrap).
DATABASE_URL=postgres://seo:seo@localhost:5432/seo_audit

# pg Pool size. Integer, default 10.
DB_POOL_SIZE=10

# PageSpeed Insights API key. Optional in Phase 0; required for Phase 4.
PSI_API_KEY=

# Crawler limits (used from Phase 1 onward).
CRAWL_MAX_PAGES=500
CRAWL_CONCURRENCY=5
CRAWL_RATE_LIMIT=5

# Max representative URLs sent to PageSpeed Insights (Phase 4).
PSI_MAX_SAMPLES=20

# --- Broken-link verification (Phase 2 enrich). After the set-based enrich
# commits, links flagged broken at crawl time are re-checked with a fresh,
# browser-like request to clear false positives (a page that momentarily 5xx'd
# under crawl load, or that blocks the crawl bot UA, but returns 200 to a real
# browser). Network I/O runs OUTSIDE the enrich transaction and is best-effort.

# Master gate for the whole pass. Boolean, default true. Set false to disable.
LINK_VERIFY_ENABLED=true

# Max simultaneous verification requests. Kept small so we don't re-trigger the
# crawl-time load that caused the false 5xx. Integer, default 5.
LINK_VERIFY_CONCURRENCY=5

# Per-request timeout in milliseconds (AbortSignal.timeout). Integer, default 10000.
LINK_VERIFY_TIMEOUT_MS=10000

# Retries per distinct URL for transient network errors (small backoff). Integer, default 2.
LINK_VERIFY_RETRIES=2

# Browser-like User-Agent for verification. Deliberately NOT the crawl bot UA —
# UA-based blocking is part of the false-positive root cause. String.
LINK_VERIFY_USER_AGENT=Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/126.0.0.0 Safari/537.36

# Cap on distinct URLs re-checked per audit (truncation is logged). Integer, default 500.
LINK_VERIFY_MAX=500

# Directory where .xlsx reports are written (Phase 5). Must be writable.
OUTPUT_DIR=./output

# HTTP port for the REST API (Phase 7). Used only by the `npm run api` entrypoint;
# the CLI never binds a port. Integer, default 3000.
API_PORT=3000

# --- Auth (Phase A0+). Used only by the `npm run api` entrypoint; the CLI is
# unauthenticated and ignores these.

# HS256 signing secret for access tokens. REQUIRED by the API entrypoint, which
# fails fast if it is unset; the CLI does not need it. Must be >= 32 chars.
# Generate one with: openssl rand -hex 32
JWT_SECRET=

# Access-token lifetime (e.g. 15m, 1h). String, default 15m.
JWT_ACCESS_TTL=15m

# Refresh-token lifetime (e.g. 30d). String, default 30d.
JWT_REFRESH_TTL=30d

# Password hashing algorithm. Enum: argon2id (default) | bcrypt. Only argon2id
# is implemented currently.
AUTH_BCRYPT_OR_ARGON=argon2id

# Failed logins before the lockout window (Phase A6). Integer, default 5.
AUTH_LOGIN_MAX_ATTEMPTS=5

# Lockout window in seconds (Phase A6). Integer, default 900.
AUTH_LOGIN_WINDOW_SEC=900

# Bootstrap admin used for first-run seeding / backfilling audit owners (§10).
# Optional. Password must be >= 12 chars when set.
AUTH_SEED_ADMIN_EMAIL=
AUTH_SEED_ADMIN_PASSWORD=
