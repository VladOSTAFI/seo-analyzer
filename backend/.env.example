# PostgreSQL connection string. Must match docker-compose.yml credentials.
# Required; validated as reachable on boot (a SELECT 1 ping runs during bootstrap).
DATABASE_URL=postgres://seo:seo@localhost:5432/seo_audit

# pg Pool size. Integer, default 10.
DB_POOL_SIZE=10

# PageSpeed Insights API key. Optional in Phase 0; required for Phase 4.
PSI_API_KEY=

# Crawler limits (used from Phase 1 onward).
CRAWL_MAX_PAGES=500
CRAWL_CONCURRENCY=5
CRAWL_RATE_LIMIT=5

# Max representative URLs sent to PageSpeed Insights (Phase 4).
PSI_MAX_SAMPLES=20

# Directory where .xlsx reports are written (Phase 5). Must be writable.
OUTPUT_DIR=./output

# HTTP port for the REST API (Phase 7). Used only by the `npm run api` entrypoint;
# the CLI never binds a port. Integer, default 3000.
API_PORT=3000
