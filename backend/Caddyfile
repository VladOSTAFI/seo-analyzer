# Reverse proxy + automatic HTTPS (Let's Encrypt) for the NestJS backend.
#
# No domain required: sslip.io is a free wildcard-DNS service where
# <ip>.sslip.io resolves to that IP automatically, so Let's Encrypt can issue a
# real, browser/Vercel-trusted cert for it. Replace the IP below with this VM's
# STATIC IP, using dashes (e.g. 203.0.113.10 -> 203-0-113-10.sslip.io).
#
# If you later buy a domain, just swap this line for `api.yourdomain.com` and
# point an A record at the IP — nothing else changes.
203-0-113-10.sslip.io {
	reverse_proxy backend:8080
}